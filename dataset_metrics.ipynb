# LLM Dataset Metrics Notebook
import json
import matplotlib.pyplot as plt

# Load sample data
with open("sample_data.json") as f:
    data = json.load(f)

# Fake correctness metric (number of words matched)
metrics = []
for item in data:
    matched_words = len(set(item["expected"].split()) & set(item["input"].split()))
    metrics.append({"id": item["id"], "correctness": matched_words})

# Plot metrics
ids = [m["id"] for m in metrics]
correctness = [m["correctness"] for m in metrics]

plt.plot(ids, correctness, marker="o")
plt.xlabel("Task ID")
plt.ylabel("Correctness Metric")
plt.title("LLM Dataset Evaluation Metrics")
plt.show()
